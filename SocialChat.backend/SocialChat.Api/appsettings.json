{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://your-production-frontend.com"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=SocialChatDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "SocialChat",
    "Audience": "SocialChatClient",
    "Secret": "YOUR_SECRET",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "MailerSend": {
    "ApiToken": "API_TOKEN",
    "FromEmail": "noreply@yourdomain.com",
    "FromName": "SocialChat",
    "BaseUrl": "https://api.mailersend.com/v1"
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_DOMAIN.googleusercontent.com"
  }
}
